  "projectType": "cli-tool",
  "projectName": "Claw Code",
  "projectDescription": "A high-performance Rust CLI agent harness that connects to Anthropic, OpenAI-compatible, and xAI providers for autonomous coding workflows, supporting interactive REPL, one-shot prompts, sessions, plugins, MCP servers, and multi-agent orchestration.",
